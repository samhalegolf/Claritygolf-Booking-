{
  "name": "clarity-booking",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/app-server.mjs",
    "serve:full": "npm run build && node server/app-server.mjs",
    "test": "NODE_NO_WARNINGS=1 node --experimental-strip-types --test tests/*.test.mjs",
    "prebuild": "npm test && npm run check:functions",
    "check:functions": "node scripts/check-functions.mjs"
  },
  "dependencies": {
    "@netlify/database": "file:netlify/functions/local-db",
    "@netlify/functions": "^5.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.555.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.7",
    "typescript": "^5.9.3"
  }
}
